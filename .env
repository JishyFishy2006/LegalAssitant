# --- Configuration for Legal RAG Assistant ---

# Embedding model used for FAISS index and queries
EMBEDDING_MODEL="nomic-embed-text"

# LLM model used for reasoning/generation (for later pipeline steps)
LLM_MODEL="llama3.1:8b"

# --- File Paths ---
# These paths are relative to the project root.
# The application will construct absolute paths.
INDEX_DIR="index"
FAISS_INDEX_FILE="faiss.index"
SQLITE_DB_FILE="meta.sqlite"
BM25_INDEX_FILE="bm25.pkl"

# --- Retriever Tuning ---
# Number of candidates to fetch from semantic search
K_SEMANTIC=10
# Number of candidates to fetch from keyword search
K_KEYWORD=10
# Minimum similarity score for semantic search results (0.0 to 1.0)
SIMILARITY_THRESHOLD=0.0
# Weight for Reciprocal Rank Fusion (0.0 to 1.0). 0.7 = 70% semantic, 30% keyword.
RRF_BETA=0.77
